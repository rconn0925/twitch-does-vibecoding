# Twitch Does Vibecoding — environment variables
# Copy to .env (gitignored). Loaded via Node's --env-file-if-exists flag (see npm run dev).
# EVERYTHING here has a safe default EXCEPT the secrets (blank below) — the app boots
# and degrades loudly without them (Twitch off, donations off), it never crashes.

# --- Phase 1: compliance gate & kill switch ---

# Operator console HTTP/ws server port (always bound to 127.0.0.1, never 0.0.0.0)
CONSOLE_PORT=4900

# SQLite audit ledger location (append-only compliance record of truth)
AUDIT_DB_PATH=./data/audit.db

# Sonnet compliance classifier billing:
# The gate bills via the Claude Agent SDK query() against your Claude plan —
# authenticate ONCE with `claude login` (plan/subscription credits). Do NOT set
# ANTHROPIC_API_KEY on the streaming machine: it silently switches the SDK to
# pay-per-token API billing (CLAUDE.md "What NOT to Use"). Leave it UNSET.

# Classifier model + retry budget (fail-closed after retries per D-11)
GATE_MODEL=claude-sonnet-5
GATE_MAX_RETRIES=2

# Per-classification timeout in ms. The Agent SDK query() spawns a CLI subprocess,
# so its cold start needs more headroom than a direct HTTP call. Default 20000;
# on timeout the gate fails closed (rejects), never open.
GATE_TIMEOUT_MS=20000

# Global panic hotkey (double-tap within ~2s to trigger per D-03)
PANIC_HOTKEY=F13

# Review-queue escalation TTL in hours (expired items logged per D-07)
REVIEW_TTL_HOURS=4

# Audit log rolling retention in days (purge job per D-17)
AUDIT_RETENTION_DAYS=90

# Log verbosity (pino): trace|debug|info|warn|error
LOG_LEVEL=info

# --- Phase 2: chat vote loop --- (SECRETS: fill these to enable Twitch chat)

# Twitch app credentials from dev.twitch.tv/console (single broadcaster token, D2-09)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Broadcaster's numeric Twitch user id — used as both broadcaster and chatting user (D2-09)
TWITCH_BROADCASTER_USER_ID=

# OAuth authorization-code callback on the localhost console surface (one-time bootstrap, D2-10)
TWITCH_REDIRECT_URI=http://localhost:4900/auth/callback

# Where the persisted auto-refreshing token JSON lives (restarts never re-auth, D2-09/INFRA-01)
TWITCH_TOKEN_PATH=./data/twitch-token.json

# NOTE ON SCOPES: the app requests user:read:chat, user:write:chat AND
# channel:read:redemptions (the last enables Phase 4 channel-points windows).
# If you authorized before Phase 4, re-visit http://127.0.0.1:4900/auth/start
# to grant the added redemptions scope.

# Voting round length in seconds; visible on the overlay (D2-02). Doubles as
# the auto-cycle VOTING-phase length — the default cadence is 40s suggest /
# 30s vote (quick-l2a).
ROUND_DURATION_SECONDS=30

# Max candidates drawn into a vote round (quick-l2a; default 5 — the vote
# panel stays scannable at five options). A SEPARATE knob from the pool cap
# and the early-close threshold below (they all default to 5 so a full pool
# becomes exactly one full vote round, but each can diverge); any undrawn
# tail stays pooled for the next round.
ROUND_MAX_OPTIONS=5

# Pool size that ends the suggestion phase EARLY (quick-l2a): the moment this
# many approved suggestions are pooled mid-suggest-phase, voting starts
# immediately through the same eligibility-checked path as timer expiry.
EARLY_CLOSE_POOL_SIZE=5

# --- auto-cycle (quick-t5k): hands-free suggest -> vote -> build cadence ---

# Auto-cycle on at boot. STRICT string check: ONLY the exact value "false"
# disables it — any other value (including "0", "FALSE", "off", or blank)
# leaves it ENABLED (D-04). Pause/resume live from the operator console.
AUTO_ROUND_ENABLED=

# Suggestion-collection window length in seconds between voting rounds (D-01)
SUGGEST_PHASE_SECONDS=40

# Vote-winner build queue cap: when this many vote winners are waiting to
# build, the scheduler pauses NEW rounds until the queue drains — a voted
# winner is never dropped. Manual Start Round is exempt (operator override).
VOTE_QUEUE_MAX=10

# Per-user cooldown between !suggest submissions, enforced BEFORE classification (D2-11)
INTAKE_COOLDOWN_SECONDS=60

# Max POOLED suggestions one user may hold at once (D2-11). Default 1 for a
# live audience (everyone gets one slot); raise for solo testing so a single
# person can fill a 2-candidate vote round alone.
INTAKE_MAX_POOLED_PER_USER=1

# Bounded candidate pool size — oldest-drop with an audit row past this (D2-13).
# Re-capped at 5 (quick-l2a user amendment): pool cap, early-close threshold,
# and vote-option draw all align at 5 by default.
POOL_MAX_SIZE=5

# Outbound chat sender budget: max messages per interval window (D2-08; broadcaster tier is 100/30s)
CHAT_SEND_INTERVAL_CAP=15
CHAT_SEND_INTERVAL_MS=30000

# Pool items older than this at win time get reclassified before enqueue (D2-05 staleness bound)
WINNER_STALENESS_MINUTES=360

# Public read-only overlay HTTP/ws port — separate surface from the console (D2-17)
OVERLAY_PORT=4901

# --- Phase 3: sandboxed build engine & live preview ---

# App-under-construction preview surface port (separate localhost surface; OBS browser source)
PREVIEW_PORT=4902

# Fixed dev-server port INSIDE the WSL2 sandbox that the preview proxies (SAND-02).
# Only ever reachable on 127.0.0.1 — never expose it. Default per SANDBOX-SETUP.md.
PREVIEW_DEV_SERVER_PORT=5555

# Single sandboxed build turn watchdog budget in seconds (WR-07). Bounds ONE
# straight-to-build turn; on timeout the build fails closed (sandbox torn down,
# narrated retry/skip decision). Default 900 (15 min) — the old 5-min bound
# aborted a live progressing build. Re-check this value at the Phase 5 dry run
# (WR-07 judgment item).
BUILD_TURN_TIMEOUT_SECONDS=900

# Model for the sandboxed build turn — explicitly pinned in options assembly so
# chat-driven builds provably run on Fable regardless of the builder account's
# ambient default (model policy, CLAUDE.md). Blank/unset -> claude-fable-5.
BUILD_MODEL=claude-fable-5

# --- Phase 4: paid influence & chaos mode ---

# StreamElements realtime JWT (SECRET — tip-triggered free-reign windows, PAID-01).
# Get it at streamelements.com -> Account Settings -> "Show secrets" -> JWT Token.
# Donations ONLY via StreamElements tips, NEVER Bits (Twitch Bits AUP). Treat like a
# password; the app never logs it. Leave blank to run with donations disabled.
STREAMELEMENTS_JWT=

# Opt-in smoke-test flag: when "true" the app ALSO accepts StreamElements DASHBOARD
# SIMULATED events (event:test) and routes them through the real tip pipeline —
# simulated tips open REAL control windows. NEVER ENABLE DURING A BROADCAST.
# Default off — leave blank/absent for normal operation; ONLY the exact string
# "true" enables it (any other value, including "1"/"TRUE", is off).
# Smoke-test procedure: docs/OPERATIONS.md §9.
SE_ACCEPT_TEST_EVENTS=

# Donation window duration = clamp(tipAmountUSD * rate, min, max) seconds (D-04, T-04-07).
# Defaults: a $5 tip ≈ 60s, a $1 tip clears the 30s floor, no tip exceeds 5 min.
DONATION_WINDOW_RATE_PER_UNIT=12
DONATION_WINDOW_MIN_SECONDS=30
DONATION_WINDOW_MAX_SECONDS=300

# Channel-points redemption window = clamp(rewardCost * rate, min, max) seconds (D-04).
# The reward's point COST is the amount input. Defaults: ~1000 points ≈ 30s, capped
# at 2 min so points windows stay shorter than tip windows. Create at least one custom
# reward that REQUIRES viewer text input — that text becomes the build instruction.
REDEMPTION_WINDOW_RATE_PER_UNIT=0.03
REDEMPTION_WINDOW_MIN_SECONDS=30
REDEMPTION_WINDOW_MAX_SECONDS=120

# Per-donor cooldown between windows, seconds — a separate guard from the one-active-window rule (D-04)
WINDOW_COOLDOWN_SECONDS=120

# Chaos-mode pick staleness bound in minutes: a candidate older than this is reclassified
# before a chaos build (mirrors the vote-winner staleness rule; D2-05)
CHAOS_STALENESS_MINUTES=360

# --- Phase 5: build-history changelog ---

# Audience-facing build-history changelog port — its own localhost surface (HIST-01)
HISTORY_PORT=4903

# --- Gallery auto-publish (quick-260711-hak): per-project public repos ---

# After each successfully COMPLETED build, the orchestrator (HOST side) pushes a
# snapshot of the workspace generation dir to ONE PUBLIC GitHub repo PER PROJECT.
# The first prompt of a generation CREATES the repo, named from that prompt
# (sanitized to a safe slug); every later prompt in the same generation pushes to
# the SAME repo. The sandboxed build agent NEVER gets GitHub access — the PAT is
# host-side only and never enters the sandbox env. Local mirror root:
# data/gallery-mirror (gitignored).

# GitHub owner (org/user) the per-project repos are created under.
GALLERY_GITHUB_OWNER=TwitchVibecodes

# Host-side GitHub PAT with `repo` scope. Used ONLY host-side (on the git/gh exec
# env, never in argv or a remote URL). Publishing AUTO-DISABLES with a loud warn
# if this is unset.
GALLERY_GITHUB_TOKEN=

# STRICT string check (AUTO_ROUND_ENABLED idiom): ONLY the exact value "false"
# disables publishing — any other value (including blank) leaves it ENABLED
# (still gated on GALLERY_GITHUB_TOKEN being present).
GALLERY_PUBLISH_ENABLED=
