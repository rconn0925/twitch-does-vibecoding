# Twitch Does Vibecoding — Phase 1 environment variables
# Copy to .env (gitignored). Loaded via Node's --env-file-if-exists flag (see npm run dev).

# Operator console HTTP/ws server port (always bound to 127.0.0.1, never 0.0.0.0)
CONSOLE_PORT=4900

# SQLite audit ledger location (append-only compliance record of truth)
AUDIT_DB_PATH=./data/audit.db

# Anthropic Messages API key for the Sonnet compliance classifier (plan 01-02).
# NOTE: metered API billing — every suggestion costs one classifier call.
ANTHROPIC_API_KEY=

# Classifier model + retry budget (plan 01-02; fail-closed after retries per D-11)
GATE_MODEL=claude-sonnet-5
GATE_MAX_RETRIES=2

# Global panic hotkey (plan 01-03; double-tap within ~2s to trigger per D-03)
PANIC_HOTKEY=F13

# Review-queue escalation TTL in hours (plan 01-05; expired items logged per D-07)
REVIEW_TTL_HOURS=4

# Audit log rolling retention in days (plan 01-04 purge job per D-17)
AUDIT_RETENTION_DAYS=90
